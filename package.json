{
  "name": "@thisismissem/adonisjs-atproto-oauth",
  "description": "Adonis.js provider for doing AT Protocol OAuth logins",
  "version": "2.0.0",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48",
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "main": "build/index.js",
  "exports": {
    ".": "./build/index.js",
    "./provider": "./build/providers/oauth_provider.js",
    "./types": "./build/src/types.js",
    "./auth/provider": "./build/src/atproto_user_provider.js",
    "./auth/user_provider": "./build/src/atproto_user_provider.js",
    "./initialize_atproto_auth_middleware": "./build/src/middleware.js"
  },
  "scripts": {
    "changeset": "changeset",
    "copy:templates": "copyfiles \"stubs/**/*.stub\" build",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm run typecheck && eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write",
    "quick:test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts",
    "pretest": "pnpm run lint",
    "test": "c8 pnpm run quick:test",
    "types:check": "attw --pack . --profile esm-only --profile node16 --ignore-rules=cjs-resolves-to-esm",
    "precompile": "npm run lint",
    "compile": "tsdown && tsc --emitDeclarationOnly --declaration",
    "postcompile": "npm run copy:templates",
    "build": "pnpm run compile",
    "version-packages": "changeset version && pnpm run format:write CHANGELOG.md && git add package.json CHANGELOG.md",
    "release": "pnpm run build && changeset publish",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "adonisjs",
    "adonis",
    "atproto",
    "at protocol",
    "oauth"
  ],
  "author": "Emelia Smith",
  "license": "MIT",
  "contributors": [
    {
      "name": "Emelia Smith",
      "url": "https://github.com/thisismissem"
    }
  ],
  "repository": {
    "url": "https://github.com/ThisIsMissEm/adonisjs-atproto-oauth"
  },
  "dependencies": {
    "@poppinss/macroable": "^1.1.0",
    "@poppinss/utils": "^7.0.1"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/core": "^7.0.1",
    "@adonisjs/eslint-config": "3.0.0",
    "@adonisjs/lucid": "^22.1.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@arethetypeswrong/cli": "^0.18.2",
    "@atproto-labs/simple-store": "^0.3.0",
    "@atproto/jwk-jose": "^0.1.11",
    "@atproto/lex": "^0.0.20",
    "@atproto/oauth-client-node": "^0.3.17",
    "@atproto/syntax": "^0.5.0",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@japa/assert": "^4.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.3.5",
    "@vinejs/vine": "^4.3.0",
    "c8": "^11.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^10.0.3",
    "luxon": "^3.7.2",
    "np": "^11.0.2",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.0",
    "typescript": "^5.4.5",
    "yalc": "1.0.0-pre.53"
  },
  "peerDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/core": "^7.0.1",
    "@adonisjs/lucid": "^22.1.0",
    "@atproto-labs/simple-store": "^0.3.0",
    "@atproto/jwk-jose": "^0.1.11",
    "@atproto/lex": "^0.0.20",
    "@atproto/oauth-client-node": "^0.3.17",
    "@vinejs/vine": "^4.3.0",
    "luxon": "^3.7.2"
  },
  "peerDependenciesMeta": {
    "@adonisjs/assembler": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "tsdown": {
    "entry": [
      "./index.ts",
      "./configure.ts",
      "./providers/oauth_provider.ts",
      "./src/atproto_user_provider.ts",
      "./src/middleware.ts",
      "./src/types.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "minify": "dce-only",
    "fixedExtension": false,
    "dts": false,
    "treeshake": false,
    "sourcemaps": false,
    "target": "esnext",
    "unbundle": true
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
